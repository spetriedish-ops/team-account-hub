  // Preserve existing anonymous ID from localStorage/cookie so Segment
  // doesn't generate a competing one.
  (function () {
    var id = null;

    function parse(raw) {
      var val = raw.replace(/^"|"$/g, '');
      return (val && val !== 'null' && val !== 'undefined') ? val : null;
    }

    try {
      var stored = localStorage.getItem('ajs_anonymous_id');
      if (stored) id = parse(stored);
    } catch (e) {}

    if (!id) {
      try {
        var match = document.cookie.match(/(?:^|;\s*)ajs_anonymous_id=([^;]*)/);
        if (match) id = parse(decodeURIComponent(match[1]));
      } catch (e) {}
